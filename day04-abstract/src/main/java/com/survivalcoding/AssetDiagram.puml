@startuml
'https://plantuml.com/class-diagram

abstract class Asset
abstract class TangibleAsset{
    String name
    int price
    String color
    double weight
}
abstract class IntangibleAsset
interface Thing{
    double getWeight()
    void setWeight(double weight)
}
class Computer{
    String makerName
}
class Book{
    String isbn
}
class Patent


Asset <|-- TangibleAsset
Asset <|-- IntangibleAsset
TangibleAsset <|-- Computer
TangibleAsset <|-- Book
IntangibleAsset <|-- Patent
Thing <|.. TangibleAsset

@enduml